             <div type="edition" subtype="ogham" xml:space="preserve" xml:lang="pgl-Ogam" resp="#POC">              
                <ab>
                    <lb n="1" style="text-direction:up"/><persName><name>ᚏᚐᚃᚐᚄ<unclear reason="damage">ᚐ</unclear></name> <w type="formula"><g ref="#forfid_X" type="interpretation_K"/>ᚑ<unclear reason="damage">ᚔ</unclear></w> <w type="formula" lemma="maqqas">ᚋᚐᚊᚊ<unclear reason="damage">ᚔ</unclear></w> <choice><unclear reason="damage">ᚇ</unclear><unclear reason="damage">ᚈ</unclear></choice><gap reason="lost" extent="unknown" unit="stroke"/>ᚂ</persName>
                    <lb n="2" style="text-direction:up"/><unclear reason="damage">ᚄᚓᚅᚅ</unclear>
                </ab> 
            </div>                    
            <div type="edition" subtype="transliteration" xml:lang="pgl-Ogam" xml:space="preserve" resp="#POC">
                <ab>
                    <lb n="1" style="text-direction:up"/><persName><name>RAVAS<unclear reason="damage">A</unclear></name> <w type="formula"><g ref="#forfid_X" type="interpretation_K"/>O<unclear reason="damage">I</unclear></w> <w type="formula" lemma="maqqas">MAQQ<unclear reason="damage">I</unclear></w> <choice><unclear reason="damage">D</unclear><unclear reason="damage">T</unclear></choice><gap reason="lost" extent="unknown" unit="stroke"/>L</persName>
                    <lb n="2" style="text-direction:up"/><unclear reason="damage">SENN</unclear>
                </ab>
            </div>
