                        <objectDesc>
                            <supportDesc>
                                <support><p><ref target="https://www.archaeology.ie/archaeological-survey-ireland/historic-environment-viewer-application">National Monuments Service</ref> SMR ID: <idno type="HER">WA003-007004-</idno></p>
                                    <material type="stone">Slate</material> 
