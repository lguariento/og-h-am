                            <origPlace><placeName type="townland">Knockboy (<distinct xml:lang="ga"><ref target="https://www.logainm.ie/en/49621">An Cnoc Buí</ref></distinct>)</placeName> <placeName type="county">Co. Waterford</placeName> <placeName type="country">Ireland</placeName>
